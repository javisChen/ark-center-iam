<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ark.center.iam.infra.user.gateway.db.UserMapper">

    <select id="selectByRoleId" resultType="com.ark.center.iam.infra.user.repository.db.UserDO">
        select u.id, u.username
        from iam_user u
        inner join iam_user_role_rel ur on ur.user_id = u.id
        where ur.role_id = #{roleId}
    </select>

</mapper>
